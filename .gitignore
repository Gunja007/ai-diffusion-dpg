# =============================================================================
# AI Composition Framework — Monorepo .gitignore
# Covers all 7 DPGs: agent_core, knowledge_engine, memory_layer, trust_layer,
# action_gateway, reach_layer, learning_layer
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# Package build artifacts
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
uv.lock

# -----------------------------------------------------------------------------
# Pytest and coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc

# -----------------------------------------------------------------------------
# Environment and secrets — never commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.*.example
*.env
secrets.yaml
secrets.json
**/config/secrets.*

# -----------------------------------------------------------------------------
# IDE and editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
docs/

# -----------------------------------------------------------------------------
# Jupyter notebooks (if used for experimentation)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
.pytype/

# -----------------------------------------------------------------------------
# Linting
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
MANIFEST
pip-wheel-metadata/
share/python-wheels/

# -----------------------------------------------------------------------------
# ChromaDB — generated vector database, never commit
# -----------------------------------------------------------------------------
**/data/chroma_db/
chroma_db/
**/data
# -----------------------------------------------------------------------------
# Sentence-transformers model cache (if downloaded locally into project)
# -----------------------------------------------------------------------------
**/models/
sentence_transformers_cache/

# -----------------------------------------------------------------------------
# macOS extended attributes
# -----------------------------------------------------------------------------
**/.DS_Store

# Git worktrees
.worktrees/
