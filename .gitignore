# =============================================================================
# AI Composition Framework — Monorepo .gitignore
# Covers all 7 DPGs: agent_core, knowledge_engine, memory_layer, trust_layer,
# action_gateway, reach_layer, learning_layer
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# Package build artifacts
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
uv.lock

# -----------------------------------------------------------------------------
# Pytest and coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc

# -----------------------------------------------------------------------------
# Environment and secrets — never commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.*.example
*.env
secrets.yaml
secrets.json
**/config/secrets.*

# -----------------------------------------------------------------------------
# IDE and editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Jupyter notebooks (if used for experimentation)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
.pytype/

# -----------------------------------------------------------------------------
# Linting
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
MANIFEST
pip-wheel-metadata/
share/python-wheels/

# -----------------------------------------------------------------------------
# ChromaDB — generated vector database, never commit
# -----------------------------------------------------------------------------
**/data/chroma_db/
chroma_db/
**/data

# -----------------------------------------------------------------------------
# SQLite audit databases — runtime-generated, never commit
# -----------------------------------------------------------------------------
**/*.db
**/*.sqlite
**/*.sqlite3
# -----------------------------------------------------------------------------
# Sentence-transformers model cache (if downloaded locally into project)
# -----------------------------------------------------------------------------
**/models/
sentence_transformers_cache/

# -----------------------------------------------------------------------------
# macOS extended attributes
# -----------------------------------------------------------------------------
**/.DS_Store

# Git worktrees
.worktrees/

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
reach_layer/web/web-src/node_modules/
reach_layer/web/dist/

# -----------------------------------------------------------------------------
# Frontend build artifacts — generated during Docker image build, never commit
# -----------------------------------------------------------------------------
dev-kit/dev_kit/agent/static/

# -----------------------------------------------------------------------------
# Local developer overrides
# -----------------------------------------------------------------------------
.env.local
**/settings.json

# -----------------------------------------------------------------------------
# Domain config meta directories
# -----------------------------------------------------------------------------
dev-kit/configs/**/_meta/
.worktrees/
test-fixtures/

# Local-only Compose overlays (host-shell secret passthrough, dev-only services, etc.)
automation/docker/docker-compose.local.yml
automation/docker/docker-compose.local.*.yml

# reach_layer_voice call recordings — local mount of /var/recordings; contains call audio (PII)
automation/docker/recordings/
dev-kit/configs/e*
dev-kit/configs/t*
dev-kit/configs/p*
dev-kit/scripts/
experiments/cache_compare/results
dev-kit/frontend-v2
# Voice audio test - generated/recorded audio samples
experiments/voice_audio_test/samples/

# Realtime voice test - per-call recordings + audio contain PII
experiments/realtime_voice_test/results/**/*.jsonl
experiments/realtime_voice_test/results/**/*.wav
