# This file overrides the root .dockerignore specifically for dev-kit/Dockerfile.
# The root .dockerignore excludes dev-kit/ for all other service images,
# but the dev-kit image obviously needs its own source tree.

# Node modules are installed inside the container; never copy from host.
dev-kit/frontend/node_modules

# Python artifacts
**/__pycache__
**/*.pyc
**/.pytest_cache
**/*.egg-info
.venv
venv

# Unrelated source modules (not needed in the dev-kit image) — exclude by
# default, then re-include only each block's MergedConfig schema for the
# pre-deploy dry-run bake-in (see Dockerfile + design doc §3).
agent_core/
knowledge_engine/
memory_layer/
trust_layer/
action_gateway/
reach_layer/
observability_layer/

# Re-include each block's runtime schema file (and parent dirs) so the
# COPY statements in dev-kit/Dockerfile resolve. Each schema is
# self-contained (only imports pydantic/enum/typing/__future__).
!agent_core/src/schema/config.py
!trust_layer/src/schema/config.py
!knowledge_engine/src/schema/config.py
!action_gateway/src/schema/config.py
!memory_layer/src/schema/config.py
!observability_layer/src/schema/config.py
!reach_layer/base/schema/config.py

# CI/CD and tooling
.git
.github
docs/

# NOTE: automation/ is intentionally NOT excluded here. The dev_kit
# image bakes automation/ at /app/automation so dev_kit.agent.app can
# read docker-compose.dev.yml and the helm charts at runtime to render
# deployment previews. The root .dockerignore still excludes it for
# every other service image.
